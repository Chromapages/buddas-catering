rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return request.auth.token.role != null 
        ? request.auth.token.role 
        : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
           ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           : 'unassigned');
    }

    function isOwner() {
      return isAuthenticated() && (getUserRole() == 'owner' || getUserRole() == 'admin');
    }

    function isRep() {
      return isAuthenticated() && getUserRole() == 'rep';
    }

    function isMarketing() {
      return isAuthenticated() && getUserRole() == 'marketing';
    }

    function isOps() {
      return isAuthenticated() && getUserRole() == 'ops';
    }

    function isPrivileged() {
      return isOwner() || isMarketing() || isOps();
    }

    function isTeamMember() {
      return isPrivileged() || isRep();
    }

    // Role-Based Rules
    
    // Default deny for safety
    match /{document=**} {
      allow read, write: if false;
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isTeamMember();
      allow create, update: if isTeamMember();
      allow delete: if isOwner();
    }

    // Contacts
    match /contacts/{contactId} {
      allow read: if isTeamMember();
      allow create, update: if isTeamMember();
      allow delete: if isOwner();
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isPrivileged() || 
                   (isRep() && resource.data.assignedRepId == request.auth.uid);
      allow create: if isTeamMember();
      allow update: if isPrivileged() || 
                    (isRep() && resource.data.assignedRepId == request.auth.uid);
      allow delete: if isOwner();
    }

    // Catering Requests
    match /cateringRequests/{requestId} {
      allow read: if isPrivileged() || 
                   (isRep() && resource.data.assignedRepId == request.auth.uid);
      allow create: if isTeamMember();
      allow update: if isPrivileged() || 
                    (isRep() && (resource == null || resource.data.assignedRepId == request.auth.uid));
      allow delete: if isOwner();
    }

    // Commitments
    match /commitments/{commitmentId} {
      allow read: if isTeamMember();
      allow create, update: if isPrivileged() || isRep();
      allow delete: if isOwner();
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isPrivileged() || 
                   (isRep() && resource.data.assignedRepId == request.auth.uid);
      allow create: if isTeamMember();
      allow update: if isPrivileged() || 
                    (isRep() && resource.data.assignedRepId == request.auth.uid);
      allow delete: if isOwner();
    }

    // Activities
    match /activities/{activityId} {
      allow read: if isTeamMember();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /commission_approvals/{approvalId} {
      allow read: if isPrivileged() || 
                  (isRep() && resource.data.repId == request.auth.uid);
      allow create: if isTeamMember();
      allow update: if isPrivileged();
      allow delete: if isOwner();
    }

    // Program Signups
    match /programSignups/{signupId} {
      allow read: if isTeamMember();
      allow create: if true; // Public signup form
      allow update: if isTeamMember();
      allow delete: if isOwner();
    }

    // Memberships
    match /memberships/{membershipId} {
      allow read: if isTeamMember();
      allow create, update: if isOwner() || isOps();
      allow delete: if isOwner();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
    }

    // Users
    match /users/{userId} {
      allow read: if isTeamMember();
      allow write: if isOwner() || request.auth.uid == userId;
    }

    // System Configuration (commission rates, feature flags, etc.)
    // Any authenticated team member may read; only owners may write.
    match /system_configs/{configId} {
      allow read: if isTeamMember();
      allow write: if isOwner();
    }

    // Invitations
    // Owners/ops create invitations; anyone can read a pending invite to accept it.
    match /invitations/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if isOwner() || isOps();
      allow update: if isAuthenticated();
      allow delete: if isOwner();
    }
  }
}
